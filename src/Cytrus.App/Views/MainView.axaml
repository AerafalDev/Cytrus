<shadui:Window xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
               xmlns:vm="using:Cytrus.App.ViewModels"
               xmlns:models="clr-namespace:Cytrus.App.Models"
               mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
               x:Class="Cytrus.App.Views.MainView"
               x:DataType="vm:MainViewModel"
               Title="Cytrus"
               Width="1060"
               Height="720"
               MinWidth="920"
               MinHeight="600"
               TitleFontWeight="SemiBold"
               WindowStartupLocation="CenterScreen">

    <shadui:Window.Hosts>
        <shadui:DialogHost Manager="{Binding DialogManager}" x:Name="PART_DialogHost" />
    </shadui:Window.Hosts>

    <Panel>
        <Grid ColumnDefinitions="400,*" Margin="20" ColumnSpacing="20">

            <Grid Grid.Column="0" RowDefinitions="*,Auto" RowSpacing="16">

                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
                    <shadui:Card>
                        <shadui:Card.Header>
                            <StackPanel>
                                <shadui:CardTitle>Download</shadui:CardTitle>
                                <shadui:CardDescription>Fetch a game build from the Ankama CDN.</shadui:CardDescription>
                            </StackPanel>
                        </shadui:Card.Header>

                        <StackPanel Spacing="14" IsEnabled="{Binding IsIdle}">
                            <TextBox Text="{Binding Game}" PlaceholderText="dofus" shadui:ControlAssist.Label="Game" />

                            <ComboBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding Platform, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" shadui:ControlAssist.Label="Platform" />

                            <TextBox Text="{Binding Release}" PlaceholderText="dofus3" shadui:ControlAssist.Label="Release" />

                            <TextBox Text="{Binding Version}" PlaceholderText="latest"
                                     shadui:ControlAssist.Label="Version (optional)" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding OutputDirectory}"
                                         shadui:ControlAssist.Label="Output directory" />
                                <Button Grid.Column="1" Classes="Outline" Content="Browse…" Click="OnBrowseClick"
                                        VerticalAlignment="Bottom" />
                            </Grid>

                            <TextBox Text="{Binding SelectPatterns}" AcceptsReturn="True" Height="72" TextWrapping="NoWrap"
                                     PlaceholderText="**/Dofus.exe&#x0a;**/*.d2i"
                                     shadui:ControlAssist.Label="Select patterns (one per line, optional)" />
                        </StackPanel>

                        <shadui:Card.Footer>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Classes="Ghost" Content="Refresh" Command="{Binding RefreshIndexCommand}" />
                                <Button Classes="Outline" Content="Cancel" Command="{Binding CancelCommand}"
                                        IsVisible="{Binding IsDownloading}" />
                                <Button Classes="Primary" Command="{Binding DownloadCommand}" IsVisible="{Binding IsIdle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Width="13" Height="13" Data="M11 3h2v8h3l-4 4-4-4h3V3z M5 19h14v2H5z" />
                                        <TextBlock Text="Download" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </shadui:Card.Footer>
                    </shadui:Card>
                </ScrollViewer>

                <shadui:Card Grid.Row="1" IsVisible="{Binding IsDownloading}">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Classes="Small"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding SpeedText}" Classes="Caption" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                            <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding BytesProgress}"
                                         Height="10" CornerRadius="5" />
                            <TextBlock Grid.Column="1" Text="{Binding BytesProgress, StringFormat='{}{0:0}%'}"
                                       FontWeight="SemiBold" MinWidth="40" TextAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </shadui:Card>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="2*,1*" RowSpacing="16">

                <shadui:Card Grid.Row="0">
                    <shadui:Card.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <shadui:CardTitle>Available versions</shadui:CardTitle>
                                <shadui:CardDescription>Click a row to fill the form.</shadui:CardDescription>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="Icon" VerticalAlignment="Top"
                                    Command="{Binding ToggleThemeCommand}"
                                    ToolTip.Tip="Toggle light / dark theme">
                                <PathIcon Width="16" Height="16" Data="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                            </Button>
                        </Grid>
                    </shadui:Card.Header>

                    <ListBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                             IsEnabled="{Binding IsIdle}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VersionRow">
                                <Grid ColumnDefinitions="1.3*,1*,1*,2.4*" ColumnSpacing="12" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="{Binding Game}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Platform}" Classes="Muted" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Release}" Classes="Muted" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding Version}" VerticalAlignment="Center" FontFamily="Cascadia Code,Consolas,monospace" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </shadui:Card>

                <shadui:Card Grid.Row="1">
                    <shadui:Card.Header>
                        <shadui:CardTitle>Log</shadui:CardTitle>
                    </shadui:Card.Header>
                    <ScrollViewer>
                        <SelectableTextBlock Text="{Binding Log}" TextWrapping="Wrap"
                                             FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
                    </ScrollViewer>
                </shadui:Card>
            </Grid>
        </Grid>

        <shadui:ToastHost Manager="{Binding ToastManager}" />
    </Panel>

</shadui:Window>

